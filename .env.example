# Tavily API key. Get one at https://tavily.com/.
TAVILY_SEARCH_API_KEY=your_tavily_key_here

# Anthropic API key. Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=your_anthropic_key_here

# Anthropic model. Default: claude-sonnet-4-6 (best for agentic multi-step writes).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Enrichment API Keys (all optional — enrichment skips missing keys)
VIRUSTOTAL_API_KEY=       # https://www.virustotal.com — free: 4 req/min
SHODAN_API_KEY=           # https://account.shodan.io — free tier available
ABUSEIPDB_API_KEY=        # https://www.abuseipdb.com — free: 1000 checks/day

# Vector store / semantic search (both optional — sensible defaults)
EMBEDDING_MODEL=all-MiniLM-L6-v2     # sentence-transformers model (downloaded on first run)
VECTOR_DB_PATH=database/chroma       # persistent Chroma directory
